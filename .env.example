# ─── Zentience Agent Environment Variables ─────────────────
# Copy to .env and fill in your values.
# NEVER commit .env — it contains secrets.
#
# These are loaded by Railway / your hosting provider.
# The code reads them from process.env — they NEVER appear
# in the frontend, console, network tab, or API responses.

# Anthropic API key for Claude inference
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Solana RPC URL (e.g., Helius, Alchemy, QuickNode)
# SECURITY: This URL contains your API key. It is ONLY used
# server-side for on-chain verification. The frontend uses
# /api/rpc proxy which strips the key before responding.
AUTOMATON_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# $ZENT token mint address (Solana SPL token)
ZENT_MINT_ADDRESS=

# Conway API key (for Conway Cloud sandbox)
CONWAY_API_KEY=

# Optional: OpenAI API key
OPENAI_API_KEY=

# Server port (default: 3000)
PORT=3000
